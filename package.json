{
  "name": "class1",
  "module": "src/index.ts",
  "type": "module",
  "private": true,
  "bin": {
    "class4": "./class4",
    "task": "./task"
  },
  "scripts": {
    "dev": "bun --hot src/index.ts",
    "dev:api": "bun --hot src/index.ts",
    "dev:web": "bun --cwd frontend run dev",
    "start": "bun src/index.ts",
    "start:mcp": "bun src/mcp/index.ts",
    "start:mcp-knowledge": "bun src/mcp/knowledge.ts",
    "mcp:observe": "bun src/mcp/observability-client.ts",
    "build:web": "bun --cwd frontend run build",
    "typecheck:web": "bun --cwd frontend run typecheck",
    "typecheck": "tsc --noEmit",
    "test": "bun test && bash test/health.test.sh && bash test/tasks.test.sh",
    "db:seed": "bun prisma/seed.ts",
    "data:backup": "bash scripts/data/backup-local.sh",
    "data:clone": "bash scripts/data/clone-database.sh",
    "data:restore": "bash scripts/data/restore-to-local.sh",
    "data:verify": "bash scripts/data/verify-database.sh",
    "data:export": "bash scripts/data/export-tasks-csv.sh",
    "cli": "bash scripts/cli.sh",
    "dev:up": "bash scripts/dev-up.sh",
    "dev:down": "bash scripts/dev-up.sh --down",
    "dev:check": "bash scripts/dev-up.sh --check"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/bun": "latest",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.6.0",
    "prisma": "6.2.1",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@prisma/client": "6.2.1",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "zod": "^4.4.3"
  }
}
